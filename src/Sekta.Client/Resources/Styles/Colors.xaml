<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Sekta Messenger Theme Colors -->
    <Color x:Key="Primary">#2AABEE</Color>
    <Color x:Key="PrimaryDark">#1E88C9</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#E8F4FD</Color>
    <Color x:Key="SecondaryDarkText">#2AABEE</Color>
    <Color x:Key="Tertiary">#1B6CA8</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#17212B</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Light Theme Colors -->
    <Color x:Key="LightBackground">#FFFFFF</Color>
    <Color x:Key="LightSurface">#F5F5F5</Color>
    <Color x:Key="LightChatBg">#E6EBF0</Color>
    <Color x:Key="LightBubbleIncoming">#FFFFFF</Color>
    <Color x:Key="LightBubbleOutgoing">#EFFDDE</Color>
    <Color x:Key="LightTextPrimary">#000000</Color>
    <Color x:Key="LightTextSecondary">#707070</Color>
    <Color x:Key="LightSeparator">#E8E8E8</Color>
    <Color x:Key="LightReplyBg">#E8F4FD</Color>
    <Color x:Key="LightReplyContentBg">#F0F0F0</Color>
    <Color x:Key="LightStickerPackBg">#F0F0F0</Color>

    <!-- Dark Theme Colors -->
    <Color x:Key="DarkBackground">#17212B</Color>
    <Color x:Key="DarkSurface">#1F2936</Color>
    <Color x:Key="DarkChatBg">#0E1621</Color>
    <Color x:Key="DarkBubbleIncoming">#182533</Color>
    <Color x:Key="DarkBubbleOutgoing">#2B5278</Color>
    <Color x:Key="DarkTextPrimary">#FFFFFF</Color>
    <Color x:Key="DarkTextSecondary">#8B9DAF</Color>
    <Color x:Key="DarkSeparator">#2B3845</Color>
    <Color x:Key="DarkReplyBg">#1F2936</Color>
    <Color x:Key="DarkReplyContentBg">#182533</Color>
    <Color x:Key="DarkStickerPackBg">#1F2936</Color>
    <Color x:Key="DarkCallBg">#0E1621</Color>
    <Color x:Key="DarkCallControl">#1F2936</Color>
    <Color x:Key="DarkTypingText">#8B9DAF</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
