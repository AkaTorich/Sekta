<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             xmlns:dto="clr-namespace:Sekta.Shared.DTOs;assembly=Sekta.Shared"
             x:Class="Sekta.Client.Views.StickersPage"
             x:DataType="vm:StickersViewModel"
             Title="Stickers"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto,*">
        <!-- Pack Tabs -->
        <Border Grid.Row="0" Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                Padding="0">
            <CollectionView ItemsSource="{Binding Packs}"
                            SelectionMode="Single"
                            ItemsLayout="HorizontalList"
                            HeightRequest="54">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:StickerPackDto">
                        <Border Padding="12,6" Margin="4,8" StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#242F3D}">
                            <Label Text="{Binding Title}" FontSize="13"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <!-- Separator -->
        <BoxView Grid.Row="0" HeightRequest="0.5"
                 Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                 VerticalOptions="End" />

        <!-- Stickers Grid -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Stickers}"
                        ItemsLayout="VerticalGrid, 4"
                        Margin="4,4">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:StickerDto">
                    <Grid Padding="4">
                        <Border Padding="6" StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                BackgroundColor="Transparent">
                            <Image Source="{Binding ImageUrl}" Aspect="AspectFit"
                                   HeightRequest="80" WidthRequest="80">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:StickersViewModel}}, Path=SelectStickerCommand}"
                                        CommandParameter="{Binding .}" />
                                </Image.GestureRecognizers>
                            </Image>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Spacing="6" Margin="0,50">
                    <Label Text="No stickers in this pack"
                           FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>

</ContentPage>
