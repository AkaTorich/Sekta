<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             x:Class="Sekta.Client.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryColor}, Dark=#17212B}">

    <Grid>
        <ScrollView VerticalOptions="Center">
            <Grid VerticalOptions="Center" Padding="30">
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2936}"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{AppThemeBinding Light=Transparent, Dark=#2B3845}"
                        Padding="30"
                        MaximumWidthRequest="400"
                        Shadow="{OnPlatform Default={Shadow Brush=#40000000, Offset='0,4', Radius=16, Opacity=0.2}}">
                    <VerticalStackLayout Spacing="18">

                        <!-- Logo area -->
                        <Border StrokeShape="RoundRectangle 40"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#E8F4FD, Dark=#242F3D}"
                                WidthRequest="80" HeightRequest="80"
                                HorizontalOptions="Center"
                                Margin="0,0,0,4">
                            <Label Text="S" FontSize="40" FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryColor}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <Label Text="Sekta"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}"
                               HorizontalOptions="Center" />

                        <Label Text="Messenger"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                               HorizontalOptions="Center"
                               Margin="0,0,0,8" />

                        <!-- Email input -->
                        <Border StrokeShape="RoundRectangle 12"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                                BackgroundColor="{AppThemeBinding Light=#F7F7F8, Dark=#242F3D}"
                                Padding="14,0"
                                HeightRequest="50">
                            <Entry Placeholder="Email"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ReturnType="Next"
                                   FontSize="15"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}" />
                        </Border>

                        <!-- Password input -->
                        <Border StrokeShape="RoundRectangle 12"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                                BackgroundColor="{AppThemeBinding Light=#F7F7F8, Dark=#242F3D}"
                                Padding="14,0"
                                HeightRequest="50">
                            <Entry Placeholder="Password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding LoginCommand}"
                                   FontSize="15"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}" />
                        </Border>

                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#FF3B30"
                               FontSize="12"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToBool}}"
                               HorizontalOptions="Center" />

                        <Button Text="Log In"
                                Command="{Binding LoginCommand}"
                                BackgroundColor="{StaticResource PrimaryColor}"
                                TextColor="White"
                                CornerRadius="24"
                                HeightRequest="50"
                                FontSize="16" FontAttributes="Bold"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                           IsVisible="{Binding IsLoading}"
                                           Color="{StaticResource PrimaryColor}" />

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,4,0,0">
                            <Label Text="Don't have an account?"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                            <Label Text="Sign Up"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryColor}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <!-- Settings gear button -->
        <Border StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                BackgroundColor="#30FFFFFF"
                WidthRequest="40" HeightRequest="40"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,20,20">
            <Label Text="&#x2699;" FontSize="22"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   TextColor="#AAFFFFFF" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding GoToSettingsCommand}" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>

</ContentPage>
