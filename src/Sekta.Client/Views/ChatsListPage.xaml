<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             xmlns:dto="clr-namespace:Sekta.Shared.DTOs;assembly=Sekta.Shared"
             xmlns:ctrl="clr-namespace:Sekta.Client.Controls"
             x:Class="Sekta.Client.Views.ChatsListPage"
             x:DataType="vm:ChatsListViewModel"
             Title="Chats"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">

    <!-- Desktop: folders | chat list | chat view -->
    <!-- Mobile: folders | chat list (full width, navigate to ChatPage on tap) -->
    <Grid x:Name="RootGrid"
          ColumnDefinitions="{OnIdiom Desktop='64,320,*', Phone='64,*'}">

        <!-- ════ Col 0: Folders Column ════ -->
        <Grid Grid.Column="0" RowDefinitions="*,Auto"
              BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0E1621}">

            <!-- Folder list -->
            <ScrollView Grid.Row="0">
                <VerticalStackLayout Spacing="6" Padding="0,8">
                    <!-- "All" button -->
                    <VerticalStackLayout Spacing="2" Padding="0,6">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectFolderCommand}"
                                                  CommandParameter="{x:Null}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="&#x1F4AC;"
                               FontSize="20"
                               TextColor="{AppThemeBinding Light=#2AABEE, Dark=#2AABEE}"
                               HorizontalOptions="Center" />
                        <Label Text="All"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555, Dark=#8B9DAF}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- User folders via BindableLayout -->
                    <VerticalStackLayout Spacing="6"
                                         BindableLayout.ItemsSource="{Binding Folders}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="dto:ChatFolderDto">
                                <VerticalStackLayout Spacing="2" Padding="0,6">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=SelectFolderCommand}"
                                            CommandParameter="{Binding .}" />
                                    </VerticalStackLayout.GestureRecognizers>
                                    <Label Text="&#x1F4C1;"
                                           FontSize="20"
                                           TextColor="{AppThemeBinding Light=#666, Dark=#8B9DAF}"
                                           HorizontalOptions="Center" />
                                    <Label Text="{Binding Name}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#555, Dark=#8B9DAF}"
                                           HorizontalOptions="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom buttons -->
            <VerticalStackLayout Grid.Row="1" Spacing="2" Padding="4,4">
                <!-- Add folder -->
                <VerticalStackLayout Spacing="2" Padding="0,6">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CreateFolderCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#x2b;"
                           FontSize="20"
                           TextColor="{AppThemeBinding Light=#2AABEE, Dark=#2AABEE}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Profile (desktop only) -->
                <VerticalStackLayout Spacing="2" Padding="0,6"
                                     IsVisible="{OnIdiom Desktop=True, Phone=False}">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#x1F464;"
                           FontSize="20"
                           TextColor="{AppThemeBinding Light=#666, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                    <Label Text="Profile"
                           FontSize="9"
                           TextColor="{AppThemeBinding Light=#555, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Settings (desktop only) -->
                <VerticalStackLayout Spacing="2" Padding="0,6"
                                     IsVisible="{OnIdiom Desktop=True, Phone=False}">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#x2699;"
                           FontSize="20"
                           TextColor="{AppThemeBinding Light=#666, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                    <Label Text="Settings"
                           FontSize="9"
                           TextColor="{AppThemeBinding Light=#555, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <!-- ════ Col 1: Chat list ════ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*"
              x:Name="ChatListPanel"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">
            <!-- Search Bar -->
            <Border Grid.Row="0" StrokeShape="RoundRectangle 18"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                    BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#242F3D}"
                    Margin="8,8,12,8" Padding="0">
                <Entry Placeholder="Search..."
                       Text="{Binding SearchText}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark=#FFFFFF}"
                       Margin="12,0" />
            </Border>

            <!-- Search Results (overlays chat list when searching) -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding SearchResults}"
                            SelectionMode="None"
                            IsVisible="{Binding IsSearching}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                            ZIndex="10">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchResultItem">
                        <Grid Padding="12,10" ColumnDefinitions="44,*" ColumnSpacing="12"
                              BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=OpenSearchResultCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Border Grid.Column="0" StrokeShape="RoundRectangle 22"
                                    Stroke="Transparent"
                                    BackgroundColor="{StaticResource PrimaryColor}"
                                    WidthRequest="44" HeightRequest="44"
                                    Padding="0" VerticalOptions="Center">
                                <Grid>
                                    <Label Text="{Binding Name, Converter={StaticResource FirstChar}}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Image Source="{Binding AvatarUrl, Converter={StaticResource MediaUrl}}"
                                           Aspect="AspectFill" />
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1" RowDefinitions="Auto,Auto" VerticalOptions="Center" RowSpacing="2">
                                <Label Grid.Row="0" Text="{Binding Name}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark=#FFFFFF}"
                                       LineBreakMode="TailTruncation" />
                                <Label Grid.Row="1" Text="{Binding Subtitle}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                                       LineBreakMode="TailTruncation" />
                            </Grid>

                            <BoxView Grid.Column="1"
                                     HeightRequest="0.5"
                                     Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                                     VerticalOptions="End" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Label Text="No results found"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Margin="0,40,0,0" />
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Chat List -->
            <RefreshView Grid.Row="1"
                         Command="{Binding RefreshCommand}"
                         IsRefreshing="{Binding IsRefreshing}"
                         IsVisible="{Binding IsSearching, Converter={StaticResource InverseBool}}">
                <CollectionView ItemsSource="{Binding Chats}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:ChatDto">
                            <SwipeView>
                                <SwipeView.LeftItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem Text="Pin"
                                                   BackgroundColor="#2AABEE"
                                                   CommandParameter="{Binding .}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=PinChatCommand}" />
                                        <SwipeItem Text="Folder"
                                                   BackgroundColor="#7C4DFF"
                                                   CommandParameter="{Binding .}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=AddChatToFolderCommand}" />
                                    </SwipeItems>
                                </SwipeView.LeftItems>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem Text="Notifications"
                                                   BackgroundColor="#FFA726"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=ToggleNotificationsCommand}" />
                                        <SwipeItem Text="Delete"
                                                   BackgroundColor="#FF3B30"
                                                   CommandParameter="{Binding .}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=DeleteChatCommand}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Grid Padding="12,10" ColumnDefinitions="54,*" ColumnSpacing="12"
                                      BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                                      Loaded="OnChatItemLoaded">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ChatsListViewModel}}, Path=OpenChatCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <!-- Avatar circle with initial + image overlay -->
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 27"
                                            Stroke="Transparent"
                                            BackgroundColor="{StaticResource PrimaryColor}"
                                            WidthRequest="54" HeightRequest="54"
                                            Padding="0" VerticalOptions="Center">
                                        <Grid>
                                            <Label Text="{Binding Title, Converter={StaticResource FirstChar}}"
                                                   FontSize="22" FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                            <Image Source="{Binding AvatarUrl, Converter={StaticResource MediaUrl}}"
                                                   Aspect="AspectFill" />
                                        </Grid>
                                    </Border>

                                    <!-- Right side: two rows -->
                                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto"
                                          VerticalOptions="Center" RowSpacing="3">

                                        <!-- Row 0: Chat name (left) + checkmarks + time (right) -->
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark=#FFFFFF}"
                                               LineBreakMode="TailTruncation"
                                               VerticalOptions="Center" />

                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="3"
                                                               HorizontalOptions="End" VerticalOptions="Center">
                                            <Label Text="{Binding LastMessage.Status, Converter={StaticResource StatusToCheck}}"
                                                   TextColor="{Binding LastMessage.Status, Converter={StaticResource StatusToCheckColor}}"
                                                   FontSize="11" VerticalOptions="Center"
                                                   IsVisible="{Binding LastMessage.SenderId, Converter={StaticResource SenderToShowCheck}}" />
                                            <Label Text="{Binding LastMessage.CreatedAt, Converter={StaticResource DateTimeToString}}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <!-- Row 1: Message preview (left) + unread badge (right) -->
                                        <Label Grid.Row="1" Grid.Column="0"
                                               Text="{Binding LastMessage, Converter={StaticResource LastMessagePreview}}"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"
                                               VerticalOptions="Center" />

                                        <Border Grid.Row="1" Grid.Column="1"
                                                BackgroundColor="{StaticResource PrimaryColor}"
                                                StrokeShape="RoundRectangle 11"
                                                Stroke="Transparent"
                                                Padding="7,2"
                                                MinimumWidthRequest="24"
                                                HeightRequest="22"
                                                IsVisible="{Binding UnreadCount, Converter={StaticResource NullToBool}}"
                                                HorizontalOptions="End" VerticalOptions="Center">
                                            <Label Text="{Binding UnreadCount}"
                                                   TextColor="White" FontSize="12"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                    <!-- Separator -->
                                    <BoxView Grid.Column="1"
                                             HeightRequest="0.5"
                                             Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                                             VerticalOptions="End" />
                                </Grid>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10"
                                             Padding="30">
                            <Label Text="No chats yet"
                                   FontSize="18" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                                   HorizontalOptions="Center" />
                            <Label Text="Start a conversation from Contacts"
                                   FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </RefreshView>

        </Grid>

        <!-- ════ Col 2: Embedded Chat (Desktop only) ════ -->
        <Grid Grid.Column="{OnIdiom Desktop=2, Phone=1}"
              x:Name="ChatPanel"
              IsVisible="{OnIdiom Desktop=True, Phone=False}"
              BackgroundColor="{AppThemeBinding Light=#E6EBF0, Dark=#0E1621}">

            <!-- Placeholder when no chat is open -->
            <VerticalStackLayout x:Name="NoChatPlaceholder"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <Label Text="Select a chat"
                       FontSize="20"
                       TextColor="{AppThemeBinding Light=#888, Dark=#8B9DAF}"
                       HorizontalOptions="Center" />
                <Label Text="Choose a conversation from the list"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#AAA, Dark=#5A6A7A}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Embedded chat view (created lazily in code-behind to avoid iOS AOT crash) -->
            <ContentView x:Name="EmbeddedChatHost" IsVisible="False" />
        </Grid>
    </Grid>

</ContentPage>
