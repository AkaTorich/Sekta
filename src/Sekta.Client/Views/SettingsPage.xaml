<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             x:Class="Sekta.Client.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0E1621}">

    <Grid RowDefinitions="Auto,*">
        <!-- Close button -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 16"
                Stroke="Transparent" BackgroundColor="#30FFFFFF"
                WidthRequest="36" HeightRequest="36"
                HorizontalOptions="End" Margin="0,10,14,0">
            <Label Text="&#x2715;" FontSize="18"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseCommand}" />
            </Border.GestureRecognizers>
        </Border>

    <ScrollView Grid.Row="1">
        <VerticalStackLayout Spacing="0" Padding="0,10,0,20">

            <!-- Connection section -->
            <Label Text="CONNECTION" FontSize="12" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryColor}"
                   Padding="16,10,16,6" CharacterSpacing="1" />

            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                    StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                    Margin="14,0" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Server URL" FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                            BackgroundColor="{AppThemeBinding Light=#F7F7F8, Dark=#1F2936}"
                            Padding="12,0" HeightRequest="44">
                        <Entry Text="{Binding ServerUrl}" Placeholder="https://localhost:5001"
                               FontSize="14" BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                               PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Appearance section -->
            <Label Text="APPEARANCE" FontSize="12" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryColor}"
                   Padding="16,18,16,6" CharacterSpacing="1" />

            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                    StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                    Margin="14,0" Padding="16,4">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="50">
                        <Label Grid.Column="0" Text="Dark Mode" FontSize="15" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        <Switch Grid.Column="1" IsToggled="{Binding DarkMode}"
                                OnColor="{StaticResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Notifications section -->
            <Label Text="NOTIFICATIONS" FontSize="12" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryColor}"
                   Padding="16,18,16,6" CharacterSpacing="1" />

            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                    StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                    Margin="14,0" Padding="16,4">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="50">
                        <Label Grid.Column="0" Text="Notifications" FontSize="15" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        <Switch Grid.Column="1" IsToggled="{Binding NotificationsEnabled}"
                                OnColor="{StaticResource PrimaryColor}"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Save button -->
            <Button Text="Save Settings"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource PrimaryColor}"
                    TextColor="White" CornerRadius="24"
                    HeightRequest="48" FontSize="16" FontAttributes="Bold"
                    Margin="14,20,14,0" />

            <!-- App info -->
            <Label Text="Sekta Messenger v1.0"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                   HorizontalOptions="Center"
                   Margin="0,24,0,0" />

        </VerticalStackLayout>
    </ScrollView>
    </Grid>

</ContentPage>
