<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             xmlns:dto="clr-namespace:Sekta.Shared.DTOs;assembly=Sekta.Shared"
             x:Class="Sekta.Client.Views.ChannelPage"
             x:DataType="vm:ChannelViewModel"
             Title="{Binding ChannelTitle}"
             BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0E1621}"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Channel Header -->
        <Grid Grid.Row="0" Padding="15,12" BackgroundColor="{StaticResource PrimaryColor}"
              ColumnDefinitions="52,*,Auto" ColumnSpacing="12">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 26"
                    Stroke="Transparent"
                    WidthRequest="52" HeightRequest="52" Padding="0">
                <Image Source="{Binding AvatarUrl, TargetNullValue='default_avatar.png'}" Aspect="AspectFill" />
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="{Binding ChannelTitle}" FontSize="18" FontAttributes="Bold" TextColor="White" />
                <Label Text="{Binding SubscriberCount, StringFormat='{0} subscribers'}"
                       FontSize="12" TextColor="{AppThemeBinding Light=#D0E8F2, Dark=#8B9DAF}" />
            </VerticalStackLayout>
            <Button Grid.Column="2" Text="{Binding SubscribeButtonText}"
                    Command="{Binding ToggleSubscribeCommand}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2936}" TextColor="{StaticResource PrimaryColor}"
                    CornerRadius="16" HeightRequest="34" FontSize="12" Padding="14,0" />
        </Grid>

        <!-- Channel Description -->
        <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                Stroke="Transparent" Padding="16,10"
                IsVisible="{Binding Description, Converter={StaticResource NullToBool}}">
            <Label Text="{Binding Description}"
                   FontSize="13" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
        </Border>

        <!-- Posts -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Posts}" Margin="8,5">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:ChannelPostDto">
                    <Border Margin="0,4" Padding="14,12" StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                            Shadow="{OnPlatform Default={Shadow Brush=#10000000, Offset='0,1', Radius=3, Opacity=0.1}}">
                        <VerticalStackLayout Spacing="8">
                            <!-- Post Content -->
                            <Label Text="{Binding Content}" FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark=#FFFFFF}"
                                   IsVisible="{Binding Content, Converter={StaticResource NullToBool}}" />
                            <!-- Media -->
                            <Image Source="{Binding MediaUrl}" MaximumHeightRequest="300"
                                   Aspect="AspectFit"
                                   IsVisible="{Binding MediaUrl, Converter={StaticResource NullToBool}}" />
                            <!-- Time -->
                            <Label Text="{Binding CreatedAt, Converter={StaticResource MessageTime}}"
                                   FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                                   HorizontalOptions="End" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No posts yet" FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                       HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- New Post Input (visible only for owner) -->
        <Border Grid.Row="3" BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                Stroke="Transparent" Padding="8,6"
                IsVisible="{Binding IsOwner}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 18"
                        Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                        BackgroundColor="{AppThemeBinding Light=#F7F7F8, Dark=#1F2936}"
                        Padding="12,4">
                    <Editor Text="{Binding NewPostText}"
                            Placeholder="Write a post..." FontSize="14" HeightRequest="40"
                            AutoSize="TextChanges" MaximumHeightRequest="120"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                            PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}" />
                </Border>
                <Button Grid.Column="1" Text="Post"
                        Command="{Binding CreatePostCommand}"
                        BackgroundColor="{StaticResource PrimaryColor}"
                        TextColor="White" CornerRadius="20"
                        WidthRequest="64" HeightRequest="40" FontSize="13" Padding="0" />
            </Grid>
        </Border>
    </Grid>

</ContentPage>
