<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             x:Class="Sekta.Client.Views.UserProfilePage"
             x:DataType="vm:UserProfileViewModel"
             Title="Profile"
             BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0E1621}"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto,*">
        <!-- Close button -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 16"
                Stroke="Transparent" BackgroundColor="#30FFFFFF"
                WidthRequest="36" HeightRequest="36"
                HorizontalOptions="End" Margin="0,10,14,0"
                ZIndex="10">
            <Label Text="&#x2715;" FontSize="18"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseCommand}" />
            </Border.GestureRecognizers>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Header with avatar -->
                <Grid BackgroundColor="{StaticResource PrimaryColor}"
                      HeightRequest="180" Padding="20">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                        <Border StrokeShape="RoundRectangle 60"
                                Stroke="White" StrokeThickness="3"
                                WidthRequest="120" HeightRequest="120"
                                BackgroundColor="{StaticResource PrimaryDarkColor}"
                                Padding="0"
                                HorizontalOptions="Center">
                            <Grid>
                                <Label Text="{Binding DisplayName, Converter={StaticResource FirstChar}}"
                                       FontSize="44" FontAttributes="Bold" TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Image Source="{Binding AvatarUrl, Converter={StaticResource MediaUrl}}"
                                       Aspect="AspectFill" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Name & status -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                        Margin="14,14,14,0" Padding="16,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding DisplayName}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        <Label Text="{Binding StatusText}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource OnlineColor}, Dark={StaticResource OnlineColor}}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Info -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                        Margin="14,10,14,0" Padding="16,12">
                    <VerticalStackLayout Spacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Username" FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                            <Label Text="{Binding Username, StringFormat='@{0}'}"
                                   FontSize="15"
                                   TextColor="{StaticResource PrimaryColor}" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="0.5"
                                 Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Bio" FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                            <Label Text="{Binding Bio}"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource PrimaryColor}" Margin="0,20,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
