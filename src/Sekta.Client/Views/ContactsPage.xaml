<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             xmlns:dto="clr-namespace:Sekta.Shared.DTOs;assembly=Sekta.Shared"
             x:Class="Sekta.Client.Views.ContactsPage"
             x:DataType="vm:ContactsViewModel"
             Title="Contacts"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Search -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 18"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#242F3D}"
                Margin="12,8" Padding="0">
            <SearchBar Placeholder="Search users..."
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding SearchUsersCommand}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}"
                       CancelButtonColor="{StaticResource PrimaryColor}" />
        </Border>

        <!-- Search Results -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding SearchResults}"
                        IsVisible="{Binding IsSearching}"
                        MaximumHeightRequest="200"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F2936}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:UserSearchResultDto">
                    <Grid Padding="14,8" ColumnDefinitions="42,*,Auto" ColumnSpacing="10"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 21"
                                Stroke="Transparent"
                                WidthRequest="42" HeightRequest="42" Padding="0">
                            <Image Source="{Binding AvatarUrl, TargetNullValue='default_avatar.png'}"
                                   Aspect="AspectFill" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding DisplayName}" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                            <Label Text="{Binding Username, StringFormat='@{0}'}"
                                   FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="Add"
                                CommandParameter="{Binding .}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ContactsViewModel}}, Path=AddContactCommand}"
                                BackgroundColor="{StaticResource PrimaryColor}"
                                TextColor="White" CornerRadius="16"
                                HeightRequest="32" FontSize="12" Padding="14,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Contacts List -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Contacts}">
            <CollectionView.Header>
                <Label Text="MY CONTACTS" FontSize="12" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                       Padding="16,14,16,6"
                       CharacterSpacing="1" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:UserDto">
                    <Grid Padding="14,10" ColumnDefinitions="52,*,Auto" ColumnSpacing="12"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">
                        <!-- Avatar with online status dot -->
                        <Grid Grid.Column="0">
                            <Border StrokeShape="RoundRectangle 26"
                                    Stroke="Transparent"
                                    WidthRequest="52" HeightRequest="52" Padding="0">
                                <Image Source="{Binding AvatarUrl, TargetNullValue='default_avatar.png'}"
                                       Aspect="AspectFill" />
                            </Border>
                            <!-- Online status indicator -->
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{AppThemeBinding Light=White, Dark=#17212B}"
                                    StrokeThickness="2"
                                    BackgroundColor="{Binding Status, Converter={StaticResource StatusToColor}}"
                                    WidthRequest="16" HeightRequest="16"
                                    HorizontalOptions="End" VerticalOptions="End" />
                        </Grid>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding DisplayName}" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                            <Label Text="{Binding Username, StringFormat='@{0}'}"
                                   FontSize="13" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                        </VerticalStackLayout>

                        <Button Grid.Column="2" Text="Chat"
                                CommandParameter="{Binding .}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ContactsViewModel}}, Path=StartChatCommand}"
                                BackgroundColor="{StaticResource PrimaryColor}"
                                TextColor="White" CornerRadius="16"
                                HeightRequest="34" FontSize="13" Padding="14,0" />

                        <!-- Separator -->
                        <BoxView Grid.Column="1" Grid.ColumnSpan="2"
                                 HeightRequest="0.5"
                                 Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                                 VerticalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Spacing="8" Margin="0,60">
                    <Label Text="No contacts yet"
                           FontSize="18" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                    <Label Text="Search for users above to add contacts"
                           FontSize="14" TextColor="{AppThemeBinding Light=#999999, Dark=#6B7D8D}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>

</ContentPage>
