<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             xmlns:dto="clr-namespace:Sekta.Shared.DTOs;assembly=Sekta.Shared"
             x:Class="Sekta.Client.Views.ForwardPage"
             x:DataType="vm:ForwardViewModel"
             Title="Forward to..."
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Search -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 18"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#242F3D}"
                Margin="12,10" Padding="0">
            <Entry Placeholder="Search..."
                   Text="{Binding SearchText}"
                   BackgroundColor="Transparent"
                   PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}"
                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                   Margin="14,0" />
        </Border>

        <!-- Chat list -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Chats}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:ChatDto">
                    <Grid Padding="12,10" ColumnDefinitions="48,*" ColumnSpacing="12"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ForwardViewModel}}, Path=SelectChatCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <!-- Avatar -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource PrimaryColor}"
                                WidthRequest="48" HeightRequest="48"
                                Padding="0" VerticalOptions="Center">
                            <Grid>
                                <Label Text="{Binding Title, Converter={StaticResource FirstChar}}"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Image Source="{Binding AvatarUrl, Converter={StaticResource MediaUrl}}"
                                       Aspect="AspectFill" />
                            </Grid>
                        </Border>

                        <!-- Name + subtitle -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Title}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Type}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}" />
                        </VerticalStackLayout>

                        <BoxView Grid.Column="1"
                                 HeightRequest="0.5"
                                 Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                                 VerticalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Cancel button -->
        <Button Grid.Row="2" Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="Transparent"
                TextColor="{StaticResource PrimaryColor}"
                FontSize="16"
                Margin="0,0,16,10"
                HorizontalOptions="End" />
    </Grid>

</ContentPage>
