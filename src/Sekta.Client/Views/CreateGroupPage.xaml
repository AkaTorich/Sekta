<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sekta.Client.ViewModels"
             x:Class="Sekta.Client.Views.CreateGroupPage"
             x:DataType="vm:CreateGroupViewModel"
             Title="New Group"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}"
             Shell.NavBarIsVisible="True">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Custom header with back button -->
        <Grid Grid.Row="0" Padding="8,8,16,8" ColumnDefinitions="Auto,*"
              BackgroundColor="{AppThemeBinding Light=#F7F7F8, Dark=#17212B}">
            <Button Grid.Column="0" Text="←" FontSize="22"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource PrimaryColor}"
                    Command="{Binding GoBackCommand}"
                    Padding="8,0" />
            <Label Grid.Column="1" Text="New Group"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryColor}, Dark=#FFFFFF}"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Group Name Input -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2B3845}"
                BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#242F3D}"
                Margin="16,12" Padding="12,4">
            <Entry Placeholder="Group name"
                   Text="{Binding GroupName}"
                   FontSize="16"
                   BackgroundColor="Transparent"
                   PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#8B9DAF}"
                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
        </Border>

        <!-- Selected Members Count -->
        <Label Grid.Row="2"
               Text="{Binding SelectedCount, StringFormat='Selected: {0} members'}"
               FontSize="13" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
               Padding="16,4,16,8"
               CharacterSpacing="0.5" />

        <!-- Contacts List -->
        <CollectionView Grid.Row="3" ItemsSource="{Binding Contacts}"
                        SelectionMode="None">
            <CollectionView.Header>
                <Label Text="ADD MEMBERS FROM CONTACTS"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                       Padding="16,8,16,6"
                       CharacterSpacing="1" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectableContact">
                    <Grid Padding="14,10" ColumnDefinitions="44,*,Auto" ColumnSpacing="12"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#17212B}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateGroupViewModel}}, Path=ToggleMemberCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <!-- Avatar -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 22"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource PrimaryColor}"
                                WidthRequest="44" HeightRequest="44"
                                Padding="0" VerticalOptions="Center">
                            <Grid>
                                <Label Text="{Binding User.DisplayName, Converter={StaticResource FirstChar}}"
                                       FontSize="18" FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Image Source="{Binding User.AvatarUrl, Converter={StaticResource MediaUrl}}"
                                       Aspect="AspectFill" />
                            </Grid>
                        </Border>

                        <!-- Name -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding User.DisplayName}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                            <Label Text="{Binding User.Username, StringFormat='@{0}'}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}" />
                        </VerticalStackLayout>

                        <!-- Selection indicator -->
                        <Border Grid.Column="2"
                                StrokeShape="RoundRectangle 14"
                                Stroke="{Binding IsSelected, Converter={StaticResource BoolToColor}}"
                                BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToColor}}"
                                WidthRequest="28" HeightRequest="28"
                                VerticalOptions="Center">
                            <Label Text="✓" FontSize="16"
                                   TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <!-- Separator -->
                        <BoxView Grid.Column="1" Grid.ColumnSpan="2"
                                 HeightRequest="0.5"
                                 Color="{AppThemeBinding Light=#E8E8E8, Dark=#2B3845}"
                                 VerticalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Spacing="8" Margin="0,60">
                    <Label Text="No contacts"
                           FontSize="18" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryColor}, Dark=#8B9DAF}"
                           HorizontalOptions="Center" />
                    <Label Text="Add contacts first from the Contacts tab"
                           FontSize="14" TextColor="{AppThemeBinding Light=#999999, Dark=#6B7D8D}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Create Button -->
        <Button Grid.Row="4"
                Text="Create Group"
                Command="{Binding CreateGroupCommand}"
                IsEnabled="{Binding IsCreating, Converter={StaticResource InverseBool}}"
                FontSize="16" FontAttributes="Bold"
                BackgroundColor="{StaticResource PrimaryColor}"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="50"
                Margin="16,8,16,16" />
    </Grid>

</ContentPage>
